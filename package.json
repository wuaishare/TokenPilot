{
  "name": "tokenpilot",
  "version": "0.1.0-alpha",
  "private": true,
  "description": "TokenPilot local-first automation scaffold for ChatGPT + Codex collaborative workflows",
  "type": "module",
  "bin": {
    "tokenpilot": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev:cli": "tsx src/cli/index.ts",
    "doctor": "tsx src/cli/index.ts doctor",
    "pack": "tsx src/cli/index.ts pack",
    "manifest": "tsx src/cli/index.ts manifest",
    "taskpack": "tsx src/cli/index.ts taskpack",
    "queue-pack": "tsx src/cli/index.ts queue-pack",
    "queue-taskpack": "tsx src/cli/index.ts queue-taskpack",
    "jobs": "tsx src/cli/index.ts jobs",
    "job": "tsx src/cli/index.ts job",
    "server": "tsx src/cli/index.ts server",
    "server:dist": "node dist/cli/index.js server",
    "runner": "tsx src/cli/index.ts runner",
    "verify:e2e": "tsx scripts/verify-local-e2e.ts",
    "verify:smoke": "tsx scripts/verify-local-smoke.ts",
    "mvp:start": "./scripts/macos-manage-local-server.sh start",
    "mvp:stop": "./scripts/macos-manage-local-server.sh stop",
    "mvp:restart": "./scripts/macos-manage-local-server.sh restart",
    "mvp:status": "./scripts/macos-manage-local-server.sh status",
    "verify": "npm run typecheck && npm run doctor && npm run verify:smoke && npm run verify:e2e"
  },
  "dependencies": {
    "fastify": "^5.6.1",
    "fastify-plugin": "^5.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "repomix": "^1.14.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
