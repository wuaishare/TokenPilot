{
  "name": "tokenpilot",
  "version": "0.1.0-alpha",
  "private": true,
  "description": "TokenPilot local-first automation scaffold for ChatGPT + Codex collaborative workflows",
  "type": "module",
  "bin": {
    "tokenpilot": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "npm run build:web && tsc -p tsconfig.json",
    "build:web": "vite build --config web/vite.config.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:web": "tsc --noEmit -p web/tsconfig.json",
    "dev:cli": "tsx src/cli/index.ts",
    "doctor": "tsx src/cli/index.ts doctor",
    "doctor:runtime": "./scripts/doctor-local-runtime.sh",
    "doctor:ingress": "./scripts/check-servbay-ingress.sh",
    "doctor:production": "./scripts/doctor-production.sh",
    "ingress:install": "./scripts/install-servbay-tokenpilot-vhost.sh",
    "repair:production": "./scripts/repair-production.sh",
    "verify:public-gpt-loop": "./scripts/verify-public-gpt-loop.sh",
    "pack": "tsx src/cli/index.ts pack",
    "manifest": "tsx src/cli/index.ts manifest",
    "taskpack": "tsx src/cli/index.ts taskpack",
    "queue-pack": "tsx src/cli/index.ts queue-pack",
    "queue-taskpack": "tsx src/cli/index.ts queue-taskpack",
    "queue-codex-run": "tsx src/cli/index.ts queue-codex-run",
    "jobs": "tsx src/cli/index.ts jobs",
    "job": "tsx src/cli/index.ts job",
    "server": "tsx src/cli/index.ts server",
    "server:dist": "node dist/cli/index.js server",
    "runner": "tsx src/cli/index.ts runner",
    "gpt:instructions": "tsx scripts/generate-gpt-instructions.ts",
    "verify:e2e": "tsx scripts/verify-local-e2e.ts",
    "verify:smoke": "tsx scripts/verify-local-smoke.ts",
    "verify:web:safety": "tsx scripts/verify-web-safety.ts",
    "verify:web": "npm run typecheck:web && npm run build:web && npm run verify:web:safety",
    "mvp:start": "./scripts/macos-manage-local-server.sh start",
    "mvp:stop": "./scripts/macos-manage-local-server.sh stop",
    "mvp:restart": "./scripts/macos-manage-local-server.sh restart",
    "mvp:status": "./scripts/macos-manage-local-server.sh status",
    "verify": "npm run typecheck && npm run verify:web && npm run doctor && npm run verify:smoke && npm run verify:e2e"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "fastify": "^5.6.1",
    "fastify-plugin": "^5.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@lobehub/fluent-emoji": "^4.1.0",
    "@lobehub/icons": "^5.8.0",
    "@lobehub/ui": "^5.14.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.2",
    "antd": "^6.4.2",
    "motion": "^12.38.0",
    "@types/node": "^24.7.2",
    "repomix": "^1.14.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.12"
  }
}
