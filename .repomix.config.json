{
  "output": {
    "filePath": ".tokenpilot/repomix-output.xml",
    "style": "xml"
  },
  "include": [
    "docs/**",
    "src/**",
    "openapi/**",
    "README.md",
    "package.json",
    "package-lock.json",
    "tsconfig.json",
    ".repomix.config.json",
    "AGENTS.md",
    "LICENSE"
  ],
  "ignore": {
    "useGitignore": true,
    "customPatterns": [
      ".git/**",
      ".codex/**",
      ".playwright-mcp/**",
      "dist/**",
      "node_modules/**",
      ".tokenpilot/**"
    ]
  }
}
